meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "emailOrUsername": "testuser",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("token", res.body.token);
    bru.setVar("userId", res.body.userId);
  }
}
