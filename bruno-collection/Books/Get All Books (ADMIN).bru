meta {
  name: Get All Books (ADMIN)
  type: http
  seq: 15
}

get {
  url: {{baseUrl}}/api/books?page=0&size=20&sortBy=createdAt&direction=DESC
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

params:query {
  page: 0
  size: 20
  sortBy: createdAt
  direction: DESC
}

docs {
  WARNING: This endpoint requires ADMIN role, but no user is ever assigned ADMIN role.
  This will always return 403 Forbidden. This is a known bug.
}
