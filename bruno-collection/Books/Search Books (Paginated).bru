meta {
  name: Search Books (Paginated)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/books/search-results?query=Potter&page=0&size=10
  body: none
  auth: none
}

params:query {
  query: Potter
  page: 0
  size: 10
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setVar("bookId", res.body.bookId);
  }
}
